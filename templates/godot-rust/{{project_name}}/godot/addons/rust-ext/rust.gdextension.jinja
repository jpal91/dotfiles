[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.3
reloadable = false

[libraries]
linux.debug.x86_64 =     "res://../rust/target/debug/lib{{ project_name }}_lib.so"
linux.release.x86_64 =   "res://../rust/target/release/lib{{ project_name }}_lib.so"
windows.debug.x86_64 =   "res://../rust/target/debug/{{ project_name }}_lib.dll"
windows.release.x86_64 = "res://../rust/target/release/{{ project_name }}_lib.dll"
macos.debug =            "res://../rust/target/debug/lib{{ project_name }}_lib.dylib"
macos.release =          "res://../rust/target/release/lib{{ project_name }}_lib.dylib"
macos.debug.arm64 =      "res://../rust/target/debug/lib{{ project_name }}_lib.dylib"
macos.release.arm64 =    "res://../rust/target/release/lib{{ project_name }}_lib.dylib"

[icons]
Player = "icon.png"
