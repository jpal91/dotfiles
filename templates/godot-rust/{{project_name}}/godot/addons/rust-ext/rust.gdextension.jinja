{% from pathjoin("{{ _copier_conf.src_path }}", '..', 'casing.jinja') import to_snake_case -%}
[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.3
reloadable = false

[libraries]
linux.debug.x86_64 =     "res://../rust/target/debug/lib{{ to_snake_case(project_name) }}_lib.so"
linux.release.x86_64 =   "res://../rust/target/release/lib{{ to_snake_case(project_name) }}_lib.so"
windows.debug.x86_64 =   "res://../rust/target/debug/{{ to_snake_case(project_name) }}_lib.dll"
windows.release.x86_64 = "res://../rust/target/release/{{ to_snake_case(project_name) }}_lib.dll"
macos.debug =            "res://../rust/target/debug/lib{{ to_snake_case(project_name) }}_lib.dylib"
macos.release =          "res://../rust/target/release/lib{{ to_snake_case(project_name) }}_lib.dylib"
macos.debug.arm64 =      "res://../rust/target/debug/lib{{ to_snake_case(project_name) }}_lib.dylib"
macos.release.arm64 =    "res://../rust/target/release/lib{{ to_snake_case(project_name) }}_lib.dylib"

[icons]
Player = "icon.png"
