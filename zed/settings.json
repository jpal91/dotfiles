// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_edit_predictions": false,
  "features": {
    "edit_prediction_provider": "zed"
  },
  "icon_theme": "VSCode Icons (Dark)",
  "agent": {
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "contents": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
          "web_search": true
        },
        "enable_all_context_servers": true
      }
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "deepseek",
      "model": "deepseek-reasoner"
    }
  },
  "vim_mode": true,
  "ui_font_size": 10,
  "buffer_font_size": 9,
  "buffer_font_family": "Hack Nerd Font",
  "terminal": {
    "line_height": "standard",
    "shell": {
      "program": "fish"
    }
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Mirage"
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Astro": {
      "formatter": {
        "external": {
          "command": "zed-prettier",
          "arguments": ["{buffer_path}"]
        }
      }
    },
    "SQL": {
      "formatter": null
    },
    "Python": {
      "language_servers": [
        "pyrefly",
        "ruff",
        "!basedpyright",
        "!pylsp",
        "!pyright",
        "!prettier",
        "..."
      ],
      "format_on_save": "on",
      "formatter": [
        {
          "code_actions": {
            "source.organizeImports.ruff": true,
            "source.fixAll.ruff": true
          }
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  },
  "lsp": {
    "ruff": {
      "initilization_options": {
        "settings": {
          "lineLength": 80,
          "lint": {
            "extendSelect": ["I"]
          }
        }
      },
      "binary": {
        "path": "/home/linuxbrew/.linuxbrew/bin/ruff",
        "arguments": ["server", "--preview"]
      }
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        }
      }
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "none",
              "suppressWhenArgumentMatchesName": false
            },
            "parameterTypes": {
              "enabled": false
            },
            "variableTypes": {
              "enabled": false,
              "suppressWhenTypeMatchesName": false
            },
            "propertyDeclarationTypes": {
              "enabled": false
            },
            "functionLikeReturnTypes": {
              "enabled": false
            },
            "enumMemberValues": {
              "enabled": false
            }
          }
        }
      }
    }
  }
}
